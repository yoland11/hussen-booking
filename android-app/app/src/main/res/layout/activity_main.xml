<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/intro_background">

    <WebView
        android:id="@+id/web_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent" />

    <LinearLayout
        android:id="@+id/error_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/error_panel_background"
        android:elevation="10dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="@string/error_title"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/error_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:text="@string/error_message"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/retry_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/retry_button_background"
            android:paddingStart="26dp"
            android:paddingTop="12dp"
            android:paddingEnd="26dp"
            android:paddingBottom="12dp"
            android:text="@string/retry_action"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/splash_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/intro_background"
        android:clickable="true"
        android:focusable="true">

        <View
            android:id="@+id/splash_orb_blue"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_gravity="top|start"
            android:layout_marginStart="-58dp"
            android:layout_marginTop="-38dp"
            android:alpha="0.88"
            android:background="@drawable/intro_glow_blue" />

        <View
            android:id="@+id/splash_orb_gold"
            android:layout_width="248dp"
            android:layout_height="248dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="-42dp"
            android:layout_marginBottom="36dp"
            android:alpha="0.84"
            android:background="@drawable/intro_glow_gold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:id="@+id/splash_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="@string/brand_name"
                android:textColor="@color/text_primary"
                android:textSize="29sp"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="260dp"
                android:layout_height="250dp"
                android:layout_marginTop="20dp">

                <View
                    android:id="@+id/splash_ring_outer"
                    android:layout_width="226dp"
                    android:layout_height="226dp"
                    android:layout_gravity="center"
                    android:background="@drawable/intro_ring" />

                <View
                    android:id="@+id/splash_ring_inner"
                    android:layout_width="186dp"
                    android:layout_height="186dp"
                    android:layout_gravity="center"
                    android:background="@drawable/intro_ring_soft" />

                <FrameLayout
                    android:id="@+id/logo_plate"
                    android:layout_width="188dp"
                    android:layout_height="188dp"
                    android:layout_gravity="center"
                    android:background="@drawable/intro_logo_plate"
                    android:clipToOutline="true"
                    android:elevation="8dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/app_name"
                        android:paddingStart="18dp"
                        android:paddingTop="18dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="18dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/hb_logo" />

                    <View
                        android:id="@+id/logo_shine"
                        android:layout_width="72dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/intro_shine" />
                </FrameLayout>
            </FrameLayout>

            <TextView
                android:id="@+id/splash_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:alpha="0"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:text="@string/brand_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
